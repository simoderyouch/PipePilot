# Runtime logs are generated by PipePilot and should not be versioned.
logs/*.log
logs/*.tmp

# Deployment archives can become large; only the directory placeholder is kept.
archives/*.tar.gz
archives/*.tar.xz
archives/*.zip

# Private keys and local secrets must never be committed.
*.pem
*.key
*.ppk
.env
.env.*

# Temporary demo projects created by test scenarios.
tests/tmp/

# Local editor and operating-system metadata.
.DS_Store
*.swp
*.swo
